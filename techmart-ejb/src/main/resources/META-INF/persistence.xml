<?xml version="1.0" encoding="UTF-8"?>
<persistence
        xmlns="https://jakarta.ee/xml/ns/persistence"
        version="3.0">

    <persistence-unit
            name="TechMartPU"
            transaction-type="JTA">

        <jta-data-source>
            jdbc/TechMartDS
        </jta-data-source>

        <class>com.techmart.core.entity.User</class>
        <class>com.techmart.core.entity.UserStatus</class>
        <class>com.techmart.core.entity.UserType</class>
        <class>com.techmart.core.entity.Product</class>
        <class>com.techmart.core.entity.ProductStatus</class>
        <class>com.techmart.core.entity.ProductImage</class>
        <class>com.techmart.core.entity.Category</class>
        <class>com.techmart.core.entity.Subcategory</class>
        <class>com.techmart.core.entity.UserAddress</class>


        <properties>
            <property
                    name="jakarta.persistence.schema-generation.database.action"
                    value="create"/>

            <property
                    name="eclipselink.logging.level"
                    value="FINE"/>
        </properties>

    </persistence-unit>

</persistence>